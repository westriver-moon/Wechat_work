# Flask
FLASK_ENV=development
PORT=5000
SECRET_KEY=replace_with_a_random_secret_key
AUTH_OWNER_SALT=replace_with_a_private_owner_salt
AUTH_SESSION_HOURS=8

# 微信公众号服务器配置中的 Token（用于签名校验）
WECHAT_TOKEN=replace_with_your_token

# 可选：LLM 配置（OpenAI 兼容接口，例如 DeepSeek）
# DeepSeek（推荐）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（可选，作为备用）
OPENAI_BASE_URL=replace_with_your_base_url
OPENAI_API_KEY=replace_with_your_api_key
OPENAI_MODEL=replace_with_your_model

# 通用参数
OPENAI_TIMEOUT=15
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=400
LLM_MIN_CONFIDENCE=0.60

# RAG 索引模式：1=词法检索优先（不依赖外网模型下载）；0=优先尝试向量索引
KB_FORCE_LEXICAL=1

# 功能三（人工工单）
# SQLite 数据库文件路径（相对路径基于 backend 目录）
DB_PATH=./feature3.db

# 公众号工单模式：1=开启（/wechat 收到消息后按工单处理）；0=保留旧的同步问答行为
FEATURE3_TICKET_MODE=1

# 是否自动用 AI 为工单生成答案：1=开启；0=仅人工回复（推荐默认）
FEATURE3_AUTO_AI_ANSWER=0

# worker 配置
FEATURE3_ENABLE_WORKER=1
FEATURE3_WORKER_POLL_SECONDS=1.5

# 被动回复中的帮助页面地址提示
FEATURE3_HELP_URL=https://bitist.top/freshman

# 可选：认证后启用主动客服消息推送
FEATURE3_ENABLE_WECHAT_PUSH=0
WECHAT_APPID=replace_with_your_appid
WECHAT_APPSECRET=replace_with_your_appsecret
