# Flask
FLASK_ENV=development
PORT=5000

# 微信公众号服务器配置中的 Token（用于签名校验）
WECHAT_TOKEN=replace_with_your_token

# 可选：LLM 配置（OpenAI 兼容接口，例如 DeepSeek）
# DeepSeek（推荐）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（可选，作为备用）
OPENAI_BASE_URL=replace_with_your_base_url
OPENAI_API_KEY=replace_with_your_api_key
OPENAI_MODEL=replace_with_your_model

# 通用参数
OPENAI_TIMEOUT=15
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=400
LLM_MIN_CONFIDENCE=0.60

# RAG 索引模式：1=词法检索优先（不依赖外网模型下载）；0=优先尝试向量索引
KB_FORCE_LEXICAL=1
